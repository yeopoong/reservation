TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CREDENTIALS_KEY=your_fernet_key_here
PARAMUS_EMAIL=your_email@example.com
PARAMUS_PASSWORD=your_password_here
BERGEN_USERNAME=your_bergen_login_here
BERGEN_PASSWORD=your_bergen_password_here

# Set to true on headless Linux servers when the site works without a visible browser.
# If the site behaves better with a visible browser, keep this false and run under Xvfb.
PARAMUS_HEADLESS=false
BERGEN_HEADLESS=false
